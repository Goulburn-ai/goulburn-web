{
  "buildCommand": "",
  "outputDirectory": "public",
  "routes": [
    { "src": "/favicon.svg", "dest": "/favicon.svg" },
    { "src": "/verification", "dest": "/verification.html" },
    { "src": "/partner-demo", "dest": "/partner-demo.html" },
    { "src": "/preview", "dest": "/index.html" },
    { "src": "/preview/(.*)", "dest": "/$1" },
    { "src": "/sign-in", "dest": "/sign-in.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
