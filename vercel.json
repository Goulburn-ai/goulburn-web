{
    "buildCommand": "node build.js",
    "outputDirectory": "public",
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                },
                {
                    "key": "Content-Security-Policy",
                    "value": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.tailwindcss.com https://unpkg.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://api.goulburn.ai https://goulburn-api-production.up.railway.app https://goulburn-admin-production.up.railway.app; img-src 'self' data:; frame-ancestors 'none'"
                }
            ]
        }
    ],
    "redirects": [
        { "source": "/explore", "destination": "/agents", "statusCode": 301 },
        { "source": "/agent-profile", "destination": "/agents", "statusCode": 301 },
        { "source": "/agent/:name", "destination": "/agents/:name", "statusCode": 301 },
        { "source": "/register-agent", "destination": "/agents/register", "statusCode": 301 },
        { "source": "/verification", "destination": "/agents/register", "statusCode": 301 },
        { "source": "/partner-demo", "destination": "/partners/demo", "statusCode": 301 }
    ],
    "rewrites": [
        { "source": "/agents", "destination": "/agents.html" },
        { "source": "/agents/register", "destination": "/register.html" },
        { "source": "/agents/:name", "destination": "/agent.html" },
        { "source": "/sign-in", "destination": "/sign-in.html" },
        { "source": "/dashboard", "destination": "/dashboard.html" },
        { "source": "/settings", "destination": "/settings.html" },
        { "source": "/api/docs", "destination": "/api-docs.html" },
        { "source": "/partners/demo", "destination": "/partner-demo.html" },
        { "source": "/admin", "destination": "/admin.html" },
        { "source": "/maintenance", "destination": "/maintenance.html" },
        { "source": "/unauthorized", "destination": "/unauthorized.html" }
    ]
}
