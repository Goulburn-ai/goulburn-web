{
  "buildCommand": "node build.js",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/((?!static|_next|.*\\.(?:js|css|png|jpg|svg|webp|ico|woff2)).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, s-maxage=60, stale-while-revalidate=300"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://cdnjs.cloudflare.com https://js.sentry-cdn.com https://cdn.vercel-insights.com https://cdn.jsdelivr.net https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://api.goulburn.ai https://goulburn-api-production.up.railway.app https://admin.goulburn.ai https://*.ingest.sentry.io; img-src 'self' data: https://api.dicebear.com; frame-src https://challenges.cloudflare.com; frame-ancestors 'none'; worker-src 'self'"
        }
      ]
    },
    {
      "source": "/(dashboard|settings)(/.*)?",
      "headers": [
        {
          "key": "Referrer-Policy",
          "value": "same-origin"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Service-Worker-Allowed",
          "value": "/"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/manifest+json"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=300"
        }
      ]
    }
  ],
  "redirects": [
    {
      "source": "/vs",
      "destination": "/realprobes",
      "permanent": true
    },
    {
      "source": "/verify",
      "destination": "/agents",
      "permanent": true
    },
    {
      "source": "/verify/:name",
      "destination": "/agents/:name#verification",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/pricing",
      "destination": "/pricing.html"
    },
    {
      "source": "/changelog",
      "destination": "/changelog.html"
    },
    {
      "source": "/agents",
      "destination": "/agents.html"
    },
    {
      "source": "/agents/register",
      "destination": "/register.html"
    },
    {
      "source": "/register",
      "destination": "/register-human.html"
    },
    {
      "source": "/oauth/callback",
      "destination": "/oauth-callback.html"
    },
    {
      "source": "/agents/:name",
      "destination": "/agent.html"
    },
    {
      "source": "/sign-in",
      "destination": "/sign-in.html"
    },
    {
      "source": "/dashboard/:id(\\d{18})",
      "destination": "/dashboard.html"
    },
    {
      "source": "/dashboard",
      "destination": "/dashboard.html"
    },
    {
      "source": "/capabilities",
      "destination": "/capabilities.html"
    },
    {
      "source": "/dashboard/settings/:id(\\d{18})",
      "destination": "/settings.html"
    },
    {
      "source": "/settings/:id(\\d{18})",
      "destination": "/settings.html"
    },
    {
      "source": "/settings",
      "destination": "/settings.html"
    },
    {
      "source": "/api/docs",
      "destination": "/api-docs.html"
    },
    {
      "source": "/how-it-works",
      "destination": "/how-it-works.html"
    },
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/maintenance",
      "destination": "/maintenance.html"
    },
    {
      "source": "/unauthorized",
      "destination": "/unauthorized.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/accessibility",
      "destination": "/accessibility.html"
    },
    {
      "source": "/oauth/return",
      "destination": "/oauth-return.html"
    },
    {
      "source": "/oauth/email",
      "destination": "/oauth-email.html"
    },
    {
      "source": "/oauth/2fa",
      "destination": "/oauth-2fa.html"
    },
    {
      "source": "/unsubscribe/:token",
      "destination": "https://admin.goulburn.ai/api/v1/admin/unsubscribe/:token"
    },
    {
      "source": "/share",
      "destination": "/share.html"
    },
    {
      "source": "/operator/:handle",
      "destination": "/operator.html"
    },
    {
      "source": "/operators",
      "destination": "/operators.html"
    },
    {
      "source": "/realprobes",
      "destination": "/realprobes.html"
    },
    {
      "source": "/probes",
      "destination": "/probes.html"
    }
  ]
}