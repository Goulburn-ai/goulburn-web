{
    "buildCommand": "node build.js",
    "outputDirectory": "public",
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                },
                {
                    "key": "Referrer-Policy",
                    "value": "strict-origin-when-cross-origin"
                },
                {
                    "key": "Content-Security-Policy",
                    "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://unpkg.com https://cdnjs.cloudflare.com https://js.sentry-cdn.com https://cdn.vercel-insights.com https://challenges.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://api.goulburn.ai https://goulburn-api-production.up.railway.app https://goulburn-admin-production.up.railway.app https://*.ingest.sentry.io; img-src 'self' data:; frame-src https://challenges.cloudflare.com; frame-ancestors 'none'"
                }
            ]
        }
    ],
    "redirects": [
        {
            "source": "/",
            "destination": "/maintenance",
            "statusCode": 302
        },
        {
            "source": "/agents",
            "destination": "/maintenance",
            "statusCode": 302
        },
        {
            "source": "/agents/:name",
            "destination": "/maintenance",
            "statusCode": 302
        },
        {
            "source": "/sign-in",
            "destination": "/maintenance",
            "statusCode": 302
        },
        {
            "source": "/register",
            "destination": "/maintenance",
            "statusCode": 302
        },
        {
            "source": "/agents/register",
            "destination": "/maintenance",
            "statusCode": 302
        },
        {
            "source": "/dashboard",
            "destination": "/maintenance",
            "statusCode": 302
        },
        {
            "source": "/settings",
            "destination": "/maintenance",
            "statusCode": 302
        },
        {
            "source": "/capabilities",
            "destination": "/maintenance",
            "statusCode": 302
        },
        {
            "source": "/api/docs",
            "destination": "/maintenance",
            "statusCode": 302
        },
        {
            "source": "/admin",
            "destination": "/maintenance",
            "statusCode": 302
        },
        {
            "source": "/verify/:name",
            "destination": "/maintenance",
            "statusCode": 302
        },
        {
            "source": "/about",
            "destination": "/maintenance",
            "statusCode": 302
        },
        {
            "source": "/pricing",
            "destination": "/maintenance",
            "statusCode": 302
        }
    ],
    "rewrites": [
        {
            "source": "/maintenance",
            "destination": "/maintenance.html"
        },
        {
            "source": "/privacy",
            "destination": "/privacy.html"
        },
        {
            "source": "/terms",
            "destination": "/terms.html"
        }
    ]
}